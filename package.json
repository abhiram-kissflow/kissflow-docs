{
  "name": "kissflow-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "next build --webpack",
    "dev": "next dev --webpack",
    "start": "serve out",
    "types:check": "fumadocs-mdx && next typegen && tsc --noEmit",
    "validate": "npx tsx scripts/validate-frontmatter.ts",
    "migrate": "npx tsx scripts/migrate-html-to-mdx.ts",
    "redirects": "npx tsx scripts/generate-redirects.ts",
    "graph:list": "bash scripts/codegraph-helper.sh list",
    "graph:project": "bash scripts/codegraph-helper.sh resolve",
    "graph:payload": "bash scripts/codegraph-helper.sh payload",
    "openapi:convert": "npx tsx scripts/postman-to-openapi.ts",
    "openapi:normalize-auth": "npx tsx scripts/apply-auth-normalization.ts",
    "openapi:lint": "npx redocly lint public/openapi/kissflow-api.json"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.84",
    "@ai-sdk/react": "^3.0.223",
    "@base-ui/react": "^1.6.0",
