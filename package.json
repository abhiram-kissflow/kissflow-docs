    "next": "^16.2.9",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-doodle-icons": "^1.0.0",
    "react-jsx-parser": "^2.4.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.13.0",
    "shiki": "^4.3.1",
    "streamdown": "^2.5.0",
    "tailwind-merge": "^3.3.1",
    "tokenlens": "^1.3.1",
    "turndown": "^7.2.4",
    "tw-animate-css": "^1.4.0",
    "use-stick-to-bottom": "^1.1.6",
    "zod": "^4.4.3"
